/*
Define combos here.

COMB(ident, keycodeToEmit, keySequence...)
SUBS(ident, sendStringArg, keySequence...)

Use the COMB macro for simple keycode shortcuts
Example: COMB(vol_up, KC_VOLU, KC_Y, KC_U).

Use the SUBS macro for sending strings
Example: SUBS(which, "which ", KC_W, KC_H).
*/

// Simple keycodes (Night layout)
//   name      result      chord keys
COMB(shTab,   KC_TAB,     KC_S, KC_H)    // S+H → Tab (home row left, adjacent)
COMB(ycEsc,   KC_ESC,     KC_Y, KC_C)    // Y+C → Esc (home row right, adjacent)
COMB(caSelW,  SELWORD,    KC_C, KC_A)    // C+A → SelectWord (home row right, adjacent)
COMB(tmCwT,   CW_TOGG,   KC_T, KC_M)    // T+M → CapsWord (home row left positions 4+5)
